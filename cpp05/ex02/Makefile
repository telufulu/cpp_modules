#*******************************************************************************#
#				COMPILER					#
#*******************************************************************************#
CXX		=	c++
CXXFLAGS	=	-Wall -Werror -Wextra -std=c++98

#*******************************************************************************#
#				SOURCES						#
#*******************************************************************************#
NAME		=	Bureaucrat
FILES		=	$(S)main.cpp $(S)Bureaucrat.cpp $(S)AForm.cpp \
				$(S)ShrubberyCreationForm.cpp
OBJS		=	$(FILES:$(S)%.cpp=$(O)%.o)

#*******************************************************************************#
#				DIRECTORIES					#
#*******************************************************************************#
S		=	srcs/
O		=	objs/
I		=	inc/

#*******************************************************************************#
#				RULES						#
#*******************************************************************************#
all:		$(NAME)

$(NAME):	$(OBJS)
	@$(CXX) $(CXXFLAGS) $(OBJS) -o $(NAME)

$(O)%.o:	$(S)%.cpp
	@[ -d $(O) ] || mkdir -p $(O)
	@$(CXX) $(CXXFLAGS) -I $(I) -c $< -o $@

clean:
	@rm -rf $(O)

fclean:	clean
	@rm -rf $(NAME)

re:	fclean all

.PHONY: all clean fclean re
